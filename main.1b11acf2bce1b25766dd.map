angular.module('gettext').run(['gettextCatalog', function (gettextCatalog) {
/* jshint -W100 */
    gettextCatalog.setStrings('mk', {"<a ui-sref=\"select\">Select files to geolocate</a> by querying a category or inputting a list of <code>File:</code>s.":"<a ui-sref=\"select\">Изберете податотеки за местоположување</a> by querying категорија или внесувајќи список на податотеки <code>File:</code>.","About":"За алаткава","About locator-tool":"За Местоположбеник","Also show geolocated files":"Прикажи и местоположени податотеки","Camera location via\n<a href=\"https://commons.wikimedia.org/wiki/Template:Location\" target=\"_blank\"><code class=\"mediawiki-template\">Location</code></a>":"Местоположба на апаратот преку\n<a href=\"https://commons.wikimedia.org/wiki/Template:Location\" target=\"_blank\"><code class=\"mediawiki-template\">Location</code></a>","Category":"Категорија","Depth":{"Category":"Продорност"},"Discard":"Отфрли","Edits using locator-tool":"Уредувања со Местоположбеник","End timestamp":"Завршно време","Failed to save: {{$ctrl.error.statusText}}":"Не успеав да зачувам: {{$ctrl.error.statusText}}","Fetched 0 files for category <code>{{$ctrl.category}}</code>!":"Презедов 0 податотеки од категоријата <code>{{$ctrl.category}}</code>!","Fetched 0 files for user <code>{{$ctrl.user}}</code>!":"Презедов 0 податотеки од корисникот <code>{{$ctrl.user}}</code>!","File list":"Список на податотеки","From the list of files provided, select one and click its location on an interactive map.":"Изберете една податотека од дадениот список, па стиснете на нејзината местоположба на интерактивна карта.","Geolocate files":"Местоположи податотеки","Hello {{$ctrl.userInfo}}!":"Здраво {{$ctrl.userInfo}}!","In order to allow locator-tool to modify file description pages, sign in first:":"За да му дозволите на Местоположбеник да ги менува описните страници на податотеките, најпрвин ќе треба да се најавите:","Its source code is available on <a href=\"https://github.com/simon04/locator-tool\">GitHub</a> and <a href=\"https://www.gnu.org/licenses/gpl.html\">GPL v3</a> licensed.":"Изворниот код е достапен на <a href=\"https://github.com/simon04/locator-tool\">GitHub</a> и е под лиценцата <a href=\"https://www.gnu.org/licenses/gpl.html\">ОЈЛ вер. 3</a>.","LANGUAGE":"македонски","Left click on map to set the location.":"Стиснете со левото копче за картата за да ја укажете местоположбата.","Limit":"Ограничување","Load Category to geolocate":"Вчитај категорија за местоположување","Load User files to geolocate":"Вчитај кориснички страници за местоположување","Load {{$ctrl.titleList.length}} files to geolocate":"Вчитај {{$ctrl.titleList.length}} податотеки за местоположување","Loading file details …":"Вчитувам поединости за податотеките...","Log in":"Најава","Log in using the button on the upper right corner":"Најавете се со копчето во горниот десен агол","Log out":"Одјава","Logged in as {{$ctrl.user}}":"Одјавете се како {{$ctrl.user}}","Map":"Карта","Object location via\n<a href=\"https://commons.wikimedia.org/wiki/Template:Object_location\" target=\"_blank\"><code class=\"mediawiki-template\">Object location</code></a>":"Местоположба на предметот преку\n<a href=\"https://commons.wikimedia.org/wiki/Template:Object_location\" target=\"_blank\"><code class=\"mediawiki-template\">Object location</code></a>","Press shift and click on map to set the object location.":"Држете Shift и стиснете на картата за да ја укажете местоположбата на предметот.","Repeat …":"Повтори …","Save":"Зачувај","Select files":"Избери податотеки","Select files to geolocate":"Избери податотеки за местоположување","Show Category on map":"Прикажи категорија на карта","Show User files on map":"Прикажи кориснички податотеки на карта","Show {{$ctrl.titleList.length}} files on map":"Прикажи {{$ctrl.titleList.length}} податотеки на карта","Sign in":"Зачленете се","Start timestamp":"Почетно време","This tool has been created by <a href=\"https://github.com/simon04/\">simon04</a>.":"Оваа алатка е дело на <a href=\"https://github.com/simon04/\">simon04</a>.","This tool helps to add <code class=\"mediawiki-template\">Coordinate</code> information to images on <a href=\"https://commons.wikimedia.org/\">Wikimedia Commons</a>.":"Оваа алатка служи за додавање на информации за <code class=\"mediawiki-template\">Coordinate</code> кон слики на <a href=\"https://commons.wikimedia.org/\">Ризницата</a>.","Translate locator-tool on Transifex":"Преведете го Местоположбеник на Transifex","Tutorial":"Нагледно упатство","Usage":"Употреба","User":"Корисник","User files":"Кориснички податотек","When a clipboard content containing HTML code (for instance a copied selection from a Commons gallery) is pasted here, locator-tool tries to extract <code>File:</code>s from the code.":"Кога тука ќе прекопирате содржина од меѓускладот која содржи HTML-код (на пр. копирате избрано од галерија на Ризницата), Местоположбеник ќе се обиде да ги извлече означените со<code>File:</code>од кодот.","locator-tool":"Местоположбеник","→ <a href=\"https://commons.wikimedia.org/wiki/Commons:Locator-tool\">Commons:Locator-tool</a>":"→ <a href=\"https://commons.wikimedia.org/wiki/Commons:Locator-tool\">Commons:Locator-tool/mk</a>"});
/* jshint +W100 */
}]);